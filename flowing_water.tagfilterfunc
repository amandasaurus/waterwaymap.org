# Used to detect ‚ÄúFlowing Water‚Äù, things like rivers, which should not have loops etc.

# Exclude `waterway` values which are not water.
waterway‚ààdam,weir,rapids,lock_gate,sluice_gate,security_lock,fairway,dock,boatyard,fuel,riverbank,pond,check_dam,turning_point,water_point,safe_water,derelict_canal,offshore_field,boat_lift,depth_line,floating_barrier,floodgate,flow_control,navigation,debris_screen,rock_ramp,construction‚ÜíF;

# Used for artificial pipes (cf https://github.com/amandasaurus/waterwaymap.org/issues/47)
waterway=pressurised‚ÜíF;

waterway‚ààditch,drain,tidal_channel‚ÜíF;

# Don't include seaways
# https://community.openstreetmap.org/t/osm-river-basins-website-to-show-how-are-rivers-in-osm-connected/102655/205
waterway=seaway‚ÜíF;

# Canoeists use this. This isn't water.
waterway‚ààput_in,link,egress‚ÜíF;
waterway=put_in\u{3B}egress‚ÜíF;     # semicolon in tag value messing things up

# Canoeists also use https://wiki.openstreetmap.org/wiki/Tag:waterway=access_point
# Should be mapped as node, but sometimes isnt. Exclude these loops.
waterway‚ààaccess_point‚ÜíF;

# Often locks on big rivers are `waterway=canal` with `lock=yes`. Since the
# rivers flow through them, they should be included.
waterway=canal‚àßlock‚ààyes,disused‚ÜíT;

# Some spillways are mapped as areas. They will obv. have a loop. Exclude.
waterway=spillway‚àßarea=yes‚ÜíF;
waterway=canal‚àßnatural=water‚àßusage=spillway‚ÜíF;

# The OSM community hasn't fully standardized on how to map the pipes around
# hydroelectric power stations.
# These type of ‚Äúcanals‚Äù have flowing water.
waterway=canal‚àßusage=spillway‚ÜíT;
waterway=canal‚àßusage‚ààheadrace,tailrace‚ÜíT;
waterway=canal‚àßusage=derivation‚ÜíT;    # req. from @pierzen@en.osm.town on 19.12.24
# https://github.com/amandasaurus/waterwaymap.org/issues/75#issuecomment-2562550892
waterway=canal‚àßman_made=pipeline‚ÜíT;

# Exclude all remaining canals.
waterway=canal‚ÜíF;

# Include `waterways` and exclude everything else
waterway‚ÜíT;
F;
